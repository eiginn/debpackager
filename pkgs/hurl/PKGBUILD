# shellcheck disable=SC2034
# Maintainer: Ryan Carter <ryan@frobozzelectric.org>
pkgname='hurl'
pkgver=6.1.1
pkgrel=1
arch=('amd64')
depends=()
pkgdesc='Hurl, run and test HTTP requests with plain text.'
license=('Apache License 2.0')
ghrepo='Orange-OpenSource/hurl'
url="https://github.com/${ghrepo}"

source=("https://github.com/${ghrepo}/releases/download/${pkgver}/hurl-${pkgver}-x86_64-unknown-linux-gnu.tar.gz")
#noextract=("binary-linux-amd64")
sha256sums=('SKIP')

options=('!strip')

package() {
  cd hurl-*-x86_64-unknown-linux-gnu || exit 1
  install -Dm 755 "bin/hurl" "${pkgdir}/usr/bin/hurl"
  install -Dm 755 "bin/hurlfmt" "${pkgdir}/usr/bin/hurlfmt"

  install -Dm 755 "completions/_hurl" "${pkgdir}/usr/share/zsh/vendor-completions/_hurl"
  install -Dm 755 "completions/_hurlfmt" "${pkgdir}/usr/share/zsh/vendor-completions/_hurlfmt"

  install -Dm 644 "man/man1/hurl.1.gz" "${pkgdir}/usr/share/man/man1/hurl.1.gz"
  install -Dm 644 "man/man1/hurlfmt.1.gz" "${pkgdir}/usr/share/man/man1/hurlfmt.1.gz"
}
