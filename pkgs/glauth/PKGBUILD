url="https://github.com/${ghrepo}"

source=("https://github.com/${ghrepo}/releases/download/v${pkgver}/glauth-linux-amd64")
sha256sums=('SKIP')

options=('!strip')

package() {
  install -Dm 755 "glauth-linux-amd64" "${pkgdir}/usr/bin/${pkgname}"
}
